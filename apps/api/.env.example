OPENROUTER_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Use reliable OpenRouter-backed providers plus local Ollama by default.
# Set to true only when Gemini and xAI billing/permissions are healthy.
ENABLE_DIRECT_PROVIDERS=false

OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_OPENAI_MODEL=openai/gpt-4o-mini
OPENROUTER_MISTRAL_MODEL=mistralai/mistral-small-2603
OPENROUTER_LLAMA_MODEL=meta-llama/llama-4-scout

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_REQUEST_TIMEOUT=65
